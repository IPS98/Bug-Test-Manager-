<mah:MetroWindow x:Class="BugTestManager.App.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:viewModels="clr-namespace:BugTestManager.App.ViewModels"
                 xmlns:views="clr-namespace:BugTestManager.App.Views"
                 Title="{Binding Title}"
                 Width="1180"
                 Height="720"
                 MinWidth="980"
                 MinHeight="620"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">
    <mah:MetroWindow.Resources>
        <DataTemplate DataType="{x:Type viewModels:TestSuitesViewModel}">
            <views:TestSuitesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:FieldDefinitionsViewModel}">
            <views:FieldDefinitionsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TestSessionsViewModel}">
            <views:TestSessionsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:BugReportsViewModel}">
            <views:BugReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PlaceholderPageViewModel}">
            <views:PlaceholderPageView />
        </DataTemplate>
    </mah:MetroWindow.Resources>

    <Grid Background="#F5F7FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="22"
                Background="#172033">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Bug &amp; Test Manager" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#B8C2D6"
                               Text="{Binding CurrentUserDisplay}" />

                    <TextBlock Margin="0,24,0,6"
                               FontWeight="SemiBold"
                               Foreground="#D5DCEB"
                               Text="Project" />
                    <ComboBox MinHeight="32"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding Projects}"
                              SelectedItem="{Binding SelectedProject}" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox MinHeight="30"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                MinWidth="54"
                                MinHeight="30"
                                Command="{Binding CreateProjectCommand}"
                                Content="+ Add" />
                    </Grid>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#B8C2D6"
                               Text="{Binding ProjectStatusMessage}"
                               TextWrapping="Wrap" />
                    <Button Margin="0,8,0,0"
                            MinHeight="30"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ShowDeleteProjectDialogCommand}"
                            Content="Delete Project"
                            Foreground="#FCA5A5" />
                </StackPanel>

                <ItemsControl Margin="0,24,0,0"
                              ItemsSource="{Binding Modules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,10"
                                    Padding="14"
                                    HorizontalContentAlignment="Stretch"
                                    Background="#22304A"
                                    BorderBrush="#22304A"
                                    Command="{Binding DataContext.SelectModuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Padding="{TemplateBinding Padding}"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <ContentPresenter />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#256D5A" />
                                                <Setter Property="BorderBrush" Value="#4ADE80" />
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2D3E5E" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#D5DCEB"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="{Binding CurrentPageTitle}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="15"
                           Foreground="#4A5872"
                           Text="{Binding CurrentPageDescription}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ContentControl Grid.Row="1"
                            Margin="0,22,0,0"
                            Content="{Binding CurrentPage}" />
        </Grid>

        <Border Grid.ColumnSpan="2"
                Panel.ZIndex="20"
                Background="#990F172A"
                Visibility="{Binding ProjectDeleteDialogVisibility}">
            <Border Width="500"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="{Binding ProjectDeleteTitle}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2"
                               Foreground="#64748B"
                               Text="{Binding ProjectDeleteWarning}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="4"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseDeleteProjectDialogCommand}"
                                Content="Cancel" />
                        <Button MinWidth="110"
                                MinHeight="34"
                                Command="{Binding ConfirmDeleteProjectCommand}"
                                Content="Delete Project"
                                Foreground="#B91C1C" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</mah:MetroWindow>
