<mah:MetroWindow x:Class="BugTestManager.App.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:viewModels="clr-namespace:BugTestManager.App.ViewModels"
                 xmlns:views="clr-namespace:BugTestManager.App.Views"
                 Title="{Binding Title}"
                 Width="1180"
                 Height="720"
                 MinWidth="980"
                 MinHeight="620"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">
    <mah:MetroWindow.Resources>
        <DataTemplate DataType="{x:Type viewModels:TestSuitesViewModel}">
            <views:TestSuitesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PlaceholderPageViewModel}">
            <views:PlaceholderPageView />
        </DataTemplate>
    </mah:MetroWindow.Resources>

    <Grid Background="#F5F7FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="22"
                Background="#172033">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Bug &amp; Test Manager" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#B8C2D6"
                               Text="{Binding CurrentUserDisplay}" />
                </StackPanel>

                <ItemsControl Margin="0,34,0,0"
                              ItemsSource="{Binding Modules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,10"
                                    Padding="14"
                                    HorizontalContentAlignment="Stretch"
                                    Background="#22304A"
                                    BorderBrush="#22304A"
                                    Command="{Binding DataContext.SelectModuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Padding="{TemplateBinding Padding}"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <ContentPresenter />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#256D5A" />
                                                <Setter Property="BorderBrush" Value="#4ADE80" />
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2D3E5E" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#D5DCEB"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="{Binding CurrentPageTitle}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="15"
                           Foreground="#4A5872"
                           Text="{Binding CurrentPageDescription}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ContentControl Grid.Row="1"
                            Margin="0,22,0,0"
                            Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</mah:MetroWindow>
