<mah:MetroWindow x:Class="BugTestManager.App.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 Title="{Binding Title}"
                 Width="1180"
                 Height="720"
                 MinWidth="980"
                 MinHeight="620"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">
    <Grid Background="#F5F7FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="22"
                Background="#172033">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Bug &amp; Test Manager" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#B8C2D6"
                               Text="{Binding CurrentUserDisplay}" />
                </StackPanel>

                <ItemsControl Margin="0,34,0,0"
                              ItemsSource="{Binding Modules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="14"
                                    Background="#22304A"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#B8C2D6"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="Project Skeleton" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="15"
                           Foreground="#4A5872"
                           Text="The application foundation is ready for templates, manual test sessions, bug tracking, attachments, filters, and reports."
                           TextWrapping="Wrap" />
            </StackPanel>

            <UniformGrid Grid.Row="1"
                         Margin="0,28,0,0"
                         Columns="2"
                         Rows="2">
                <Border Margin="0,0,14,14"
                        Padding="22"
                        Background="White"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Test Suites and Revisions" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#4A5872"
                                   Text="Ready to model any user-defined test base, revision, section, case, step, date, status, and attachment."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Margin="14,0,0,14"
                        Padding="22"
                        Background="White"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Dynamic Fields" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#4A5872"
                                   Text="The architecture keeps room for custom fields such as model, firmware, dates, statuses, comments, and measurements."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Margin="0,14,14,0"
                        Padding="22"
                        Background="White"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Filtering and Tags" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#4A5872"
                                   Text="Future screens will filter failed tests, unfinished bugs, versions, revisions, categories, owners, dates, and tags."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Margin="14,14,0,0"
                        Padding="22"
                        Background="White"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Reports and Attachments" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#4A5872"
                                   Text="PDF reports, screenshots, photos, bug comments, and audit history are planned as core features."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Grid>
</mah:MetroWindow>
