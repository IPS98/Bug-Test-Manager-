<UserControl x:Class="BugTestManager.App.Views.TestSuitesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:BugTestManager.App.ViewModels">
    <UserControl.Resources>
        <Style x:Key="RowActionsStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="True" />
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RowActionButtonStyle"
               BasedOn="{StaticResource IconActionButtonStyle}"
               TargetType="Button">
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="FullWidthListBoxItemStyle"
               BasedOn="{StaticResource StableListBoxItemStyle}"
               TargetType="ListBoxItem" />
    </UserControl.Resources>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="{Binding RevisionColumnWidth}" />
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Test Suites" />
                        <Button Grid.Column="1"
                                Command="{Binding ShowCreateTestSuiteDialogCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Create a new test suite">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                <TextBlock Text="New Test Suite" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border DockPanel.Dock="Bottom"
                            Margin="0,12,0,0"
                            Padding="10"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{Binding LinkedFieldsVisibility}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Linked Fields" />
                            <ItemsControl Margin="0,8,0,0"
                                          ItemsSource="{Binding LinkedFields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Name}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Foreground="#64748B"
                                                       Text="{Binding ScopeDisplayName}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding TestSuites}"
                             SelectedItem="{Binding SelectedTestSuite}"
                             ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                        <DataTemplate>
                                <StackPanel Margin="0,4,0,8">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap" />
                                    <Border Margin="0,6,0,0"
                                            Style="{StaticResource GreenChipBorderStyle}">
                                        <TextBlock Style="{StaticResource GreenChipTextStyle}"
                                                   Text="{Binding RevisionPolicyDisplay}" />
                                    </Border>
                                    <StackPanel Style="{StaticResource RowActionsStyle}">
                                        <Button Command="{Binding DataContext.ShowEditTestSuiteDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="&#xE70F;"
                                                Style="{StaticResource RowActionButtonStyle}"
                                                ToolTip="Edit test suite" />
                                        <Button Command="{Binding DataContext.ShowDeleteTestSuiteDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="&#xE74D;"
                                                Style="{StaticResource DangerIconActionButtonStyle}"
                                                ToolTip="Delete test suite and all child items" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,0,12,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="8"
                    Visibility="{Binding RevisionColumnVisibility}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Revisions" />
                        <Button Grid.Column="1"
                                Command="{Binding ShowCreateRevisionDialogCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Create a new revision">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                <TextBlock Text="Add" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListBox ItemsSource="{Binding SelectedTestSuite.Revisions}"
                             SelectedItem="{Binding SelectedRevision}"
                             ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,8">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding EffectiveDateDisplay}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EffectiveDateDisplay}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel Style="{StaticResource RowActionsStyle}">
                                        <Button Command="{Binding DataContext.ShowEditRevisionDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="&#xE70F;"
                                                Style="{StaticResource RowActionButtonStyle}"
                                                ToolTip="Edit revision" />
                                        <Button Command="{Binding DataContext.ShowDeleteRevisionDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="&#xE74D;"
                                                Style="{StaticResource DangerIconActionButtonStyle}"
                                                ToolTip="Delete revision and its tests" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Margin="0,0,12,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Sections" />
                        <Button Grid.Column="1"
                                Command="{Binding ShowCreateSectionDialogCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Create a new section">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                <TextBlock Text="Add" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListBox ItemsSource="{Binding SelectedRevision.Sections}"
                             SelectedItem="{Binding SelectedSection}"
                             ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                        <DataTemplate>
                                <StackPanel Margin="0,4,0,8">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding Category}"
                                               TextWrapping="Wrap" />
                                    <StackPanel Style="{StaticResource RowActionsStyle}">
                                        <Button Command="{Binding DataContext.ShowEditSectionDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="&#xE70F;"
                                                Style="{StaticResource RowActionButtonStyle}"
                                                ToolTip="Edit section" />
                                        <Button Command="{Binding DataContext.ShowDeleteSectionDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="&#xE74D;"
                                                Style="{StaticResource DangerIconActionButtonStyle}"
                                                ToolTip="Delete section and child items" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="16"
                        Background="White"
                        CornerRadius="8">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top"
                              Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Test Cases" />
                            <Button Grid.Column="1"
                                    Command="{Binding ShowCreateTestCaseDialogCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    ToolTip="Create a new test case">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                    <TextBlock Text="Add" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <ListBox ItemsSource="{Binding SelectedSection.TestCases}"
                                 SelectedItem="{Binding SelectedTestCase}"
                                 ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4,0,8">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Title}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="#64748B"
                                                   Text="{Binding ExpectedResult, StringFormat=Test details: {0}}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Style="{StaticResource RowActionsStyle}">
                                            <Button Command="{Binding DataContext.ShowEditTestCaseDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="&#xE70F;"
                                                    Style="{StaticResource RowActionButtonStyle}"
                                                    ToolTip="Edit test case" />
                                            <Button Command="{Binding DataContext.ShowDeleteTestCaseDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="&#xE74D;"
                                                    Style="{StaticResource DangerIconActionButtonStyle}"
                                                    ToolTip="Delete test case and checks" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2"
                        Padding="16"
                        Background="White"
                        CornerRadius="8">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top"
                              Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Checks" />
                            <Button Grid.Column="1"
                                    Command="{Binding ShowCreateTestStepDialogCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    ToolTip="Create a new check">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                    <TextBlock Text="Add" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <ListBox ItemsSource="{Binding SelectedTestCase.Steps}"
                                 SelectedItem="{Binding SelectedStep}"
                                 ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="24"
                                                Height="24"
                                                Background="#E7F6EF"
                                                CornerRadius="12">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="#256D5A"
                                                       Text="{Binding SortOrder}" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding CheckText}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#64748B"
                                                       Text="{Binding ExpectedResult, StringFormat=Test details: {0}}"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Style="{StaticResource RowActionsStyle}">
                                                <Button Command="{Binding DataContext.ShowEditTestStepDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE70F;"
                                                        Style="{StaticResource RowActionButtonStyle}"
                                                        ToolTip="Edit check" />
                                                <Button Command="{Binding DataContext.ShowDeleteTestStepDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE74D;"
                                                        Style="{StaticResource DangerIconActionButtonStyle}"
                                                        ToolTip="Delete check" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Background="#990F172A"
                Visibility="{Binding DialogOverlayVisibility}">
            <Border Width="560"
                    MaxWidth="620"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="{Binding DialogTitle}" />

                    <Grid Grid.Row="2">
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.TestSuite}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.EditTestSuite}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Foreground="#64748B" Text="Name" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding NewTestSuiteName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B" Text="Description" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="68"
                                     AcceptsReturn="True"
                                     Text="{Binding NewTestSuiteDescription, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />

                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.TestSuite}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.EditTestSuite}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <CheckBox Margin="0,0,0,14"
                                          Content="Revision required"
                                          IsChecked="{Binding NewTestSuiteRevisionIsRequired}" />

                                <TextBlock Foreground="#64748B" Text="Initial revision name" />
                                <TextBox Margin="0,6,0,0"
                                         MinHeight="34"
                                         IsEnabled="{Binding NewTestSuiteRevisionIsRequired}"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding NewTestSuiteInitialRevisionName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.Revision}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.EditRevision}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Foreground="#64748B" Text="Revision name" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding NewRevisionName, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.Revision}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Foreground="#64748B" Text="Copy tests from" />
                                <ComboBox Margin="0,6,0,0"
                                          MinHeight="34"
                                          DisplayMemberPath="Name"
                                          ItemsSource="{Binding RevisionCopySources}"
                                          SelectedItem="{Binding SelectedRevisionCopySource}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.Section}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.EditSection}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Foreground="#64748B" Text="Name" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding NewSectionName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B" Text="Category" />
                            <TextBox Margin="0,6,0,0"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding NewSectionCategory, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.TestCase}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.EditTestCase}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Foreground="#64748B" Text="Title" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding NewTestCaseTitle, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B" Text="Test details" />
                            <TextBox Margin="0,6,0,0"
                                     MinHeight="82"
                                     AcceptsReturn="True"
                                     Text="{Binding NewTestCaseExpectedResult, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.Step}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.EditStep}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Foreground="#64748B" Text="Check" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="82"
                                     AcceptsReturn="True"
                                     Text="{Binding NewStepText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />

                            <TextBlock Foreground="#64748B" Text="Test details" />
                            <TextBox Margin="0,6,0,0"
                                     MinHeight="82"
                                     AcceptsReturn="True"
                                     Text="{Binding NewStepExpectedResult, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.DeleteConfirmation}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="{Binding DeleteConfirmationMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="4"
                               Margin="0,0,0,14"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="5"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseDialogCommand}"
                                Content="Cancel"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Close this dialog without saving" />

                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding CreateTestSuiteCommand}"
                                Content="Create"
                                IsDefault="True"
                                ToolTip="Create test suite">
                            <Button.Style>
                                <Style BasedOn="{StaticResource PrimaryActionButtonStyle}" TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.TestSuite}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding CreateRevisionCommand}"
                                Content="Create"
                                IsDefault="True"
                                ToolTip="Create revision">
                            <Button.Style>
                                <Style BasedOn="{StaticResource PrimaryActionButtonStyle}" TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveDialog}" Value="{x:Static viewModels:TemplateDialogKind.Revision}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding CreateSectionCommand}"
                                Content="Create"
                                IsDefault="True"
                                ToolTip="Create section">
