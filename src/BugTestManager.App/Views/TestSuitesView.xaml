<UserControl x:Class="BugTestManager.App.Views.TestSuitesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,12,0"
                Padding="16"
                Background="White"
                CornerRadius="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,12"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="Test Suites" />
                <ListBox ItemsSource="{Binding TestSuites}"
                         SelectedItem="{Binding SelectedTestSuite}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,8">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding Name}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#64748B"
                                           Text="{Binding Description}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="#256D5A"
                                           Text="{Binding RevisionPolicyDisplay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="0,0,12,0"
                Padding="16"
                Background="White"
                CornerRadius="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,12"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="Revisions" />
                <ListBox ItemsSource="{Binding SelectedTestSuite.Revisions}"
                         SelectedItem="{Binding SelectedRevision}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,8">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding Name}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#64748B"
                                           Text="{Binding EffectiveDateDisplay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Margin="0,0,12,0"
                Padding="16"
                Background="White"
                CornerRadius="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,12"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="Sections" />
                <ListBox ItemsSource="{Binding SelectedRevision.Sections}"
                         SelectedItem="{Binding SelectedSection}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,8">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding Name}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#64748B"
                                           Text="{Binding Category}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="220" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="16"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,12"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="Test Cases" />
                    <ListBox ItemsSource="{Binding SelectedSection.TestCases}"
                             SelectedItem="{Binding SelectedTestCase}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,8">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Title}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding ExpectedResult}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Padding="16"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,12"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="Steps" />
                    <ListBox ItemsSource="{Binding SelectedTestCase.Steps}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="24"
                                            Height="24"
                                            Background="#E7F6EF"
                                            CornerRadius="12">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="#256D5A"
                                                   Text="{Binding SortOrder}" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding StepText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="#64748B"
                                                   Text="{Binding ExpectedResult}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
