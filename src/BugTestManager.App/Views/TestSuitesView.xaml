<UserControl x:Class="BugTestManager.App.Views.TestSuitesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,12,0"
                Padding="16"
                Background="White"
                CornerRadius="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,12"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="Test Suites" />
                <ListBox ItemsSource="{Binding TestSuites}"
                         SelectedItem="{Binding SelectedTestSuite}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,8">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding Name}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#64748B"
                                           Text="{Binding Description}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="#256D5A"
                                           Text="{Binding RevisionPolicyDisplay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="0,0,12,0"
                Padding="16"
                Background="White"
                CornerRadius="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,12"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="Revisions" />
                <ListBox ItemsSource="{Binding SelectedTestSuite.Revisions}"
                         SelectedItem="{Binding SelectedRevision}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,8">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding Name}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#64748B"
                                           Text="{Binding EffectiveDateDisplay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Margin="0,0,12,0"
                Padding="16"
                Background="White"
                CornerRadius="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,12"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="Sections" />
                <ListBox ItemsSource="{Binding SelectedRevision.Sections}"
                         SelectedItem="{Binding SelectedSection}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,8">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding Name}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#64748B"
                                           Text="{Binding Category}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="220" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="16"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,12"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="Test Cases" />
                    <ListBox ItemsSource="{Binding SelectedSection.TestCases}"
                             SelectedItem="{Binding SelectedTestCase}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,8">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Title}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding ExpectedResult}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Padding="16"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,12"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="Steps" />
                    <ListBox ItemsSource="{Binding SelectedTestCase.Steps}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="24"
                                            Height="24"
                                            Background="#E7F6EF"
                                            CornerRadius="12">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="#256D5A"
                                                   Text="{Binding SortOrder}" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding StepText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="#64748B"
                                                   Text="{Binding ExpectedResult}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Grid.ColumnSpan="4"
                Padding="16"
                Background="White"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.ColumnSpan="5"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="New Test Suite" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Foreground="#64748B"
                               Text="Name" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Foreground="#64748B"
                               Text="Description" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="4"
                               Foreground="#64748B"
                               Text="Policy" />

                    <TextBox Grid.Row="4"
                             Grid.Column="0"
                             MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewTestSuiteName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Row="4"
                             Grid.Column="2"
                             MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewTestSuiteDescription, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Grid.Row="4"
                              Grid.Column="4"
                              VerticalAlignment="Center"
                              Content="Revision required"
                              IsChecked="{Binding NewTestSuiteRevisionIsRequired}" />

                    <TextBox Grid.Row="6"
                             Grid.Column="0"
                             MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewTestSuiteInitialRevisionName, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Row="6"
                            Grid.Column="4"
                            MinHeight="34"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CreateTestSuiteCommand}"
                            Content="Create" />

                    <TextBlock Grid.Row="6"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Foreground="#64748B"
                               Text="Initial revision name, only when needed" />
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.ColumnSpan="5"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="New Section" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Foreground="#64748B"
                               Text="Name" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Foreground="#64748B"
                               Text="Category" />

                    <TextBox Grid.Row="4"
                             Grid.Column="0"
                             MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewSectionName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Row="4"
                             Grid.Column="2"
                             MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewSectionCategory, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Row="4"
                            Grid.Column="4"
                            MinHeight="34"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CreateSectionCommand}"
                            Content="Create" />

                    <TextBlock Grid.Row="6"
                               Grid.ColumnSpan="5"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
