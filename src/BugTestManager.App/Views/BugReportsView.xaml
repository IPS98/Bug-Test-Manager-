<UserControl x:Class="BugTestManager.App.Views.BugReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:BugTestManager.App.Views.Shared">
    <UserControl.Resources>
        <Style x:Key="FullWidthListBoxItemStyle"
               BasedOn="{StaticResource StableListBoxItemStyle}"
               TargetType="ListBoxItem" />

        <Style x:Key="SmallActionButtonStyle"
               BasedOn="{StaticResource ActionButtonStyle}"
               TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18"
                    Background="White"
                    CornerRadius="8"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="New Bug" />

                    <TextBlock Margin="0,18,0,6"
                               Foreground="#64748B"
                               Text="Title" />
                    <TextBox MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewBugTitle, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Description" />
                    <TextBox MinHeight="110"
                             AcceptsReturn="True"
                             Text="{Binding NewBugDescription, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Severity" />
                    <TextBox MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewBugSeverity, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Priority" />
                    <TextBox MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewBugPriority, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Found in version" />
                    <TextBox MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewBugFoundInVersion, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Build number" />
                    <TextBox MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewBugBuildNumber, UpdateSourceTrigger=PropertyChanged}" />

                    <shared:CustomFieldValuesEditor DataContext="{Binding NewBugCustomFields}" />

                    <Button Margin="0,18,0,0"
                            MinHeight="36"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CreateBugCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            ToolTip="Create bug">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                            <TextBlock Text="Create Bug" />
                        </StackPanel>
                    </Button>

                    <TextBlock Margin="0,14,0,0"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Padding="18"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Bug Tracker" />
                        <Button Grid.Column="1"
                                Command="{Binding ShowNewBugDialogCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Create a new bug report">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                <TextBlock Text="New Bug" />
                            </StackPanel>
                        </Button>
                        <ComboBox Grid.Column="3"
                                  MinHeight="34"
                                  Margin="0,0,10,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding BugStatuses}"
                                  SelectedItem="{Binding SelectedBugStatus}" />
                        <Button Grid.Column="4"
                                Command="{Binding UpdateBugStatusCommand}"
                                Content="Update Status"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Update selected bug status" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Margin="0,0,0,5"
                                       Foreground="#64748B"
                                       Text="Status filter" />
                            <ComboBox MinHeight="32"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding BugStatusFilters}"
                                      SelectedItem="{Binding SelectedBugStatusFilter}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Margin="0,0,0,5"
                                       Foreground="#64748B"
                                       Text="Severity filter" />
                            <ComboBox MinHeight="32"
                                      ItemsSource="{Binding SeverityFilters}"
                                      SelectedItem="{Binding SelectedSeverityFilter}" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Margin="0,0,0,5"
                                       Foreground="#64748B"
                                       Text="Priority filter" />
                            <ComboBox MinHeight="32"
                                      ItemsSource="{Binding PriorityFilters}"
                                      SelectedItem="{Binding SelectedPriorityFilter}" />
                        </StackPanel>
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Bugs}"
                             SelectedItem="{Binding SelectedBug}"
                             ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4,0,12"
                                        Padding="14"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding DataContext.OpenBugDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <Border DockPanel.Dock="Right"
                                                    Padding="8,3"
                                                    Background="{Binding StatusBackground}"
                                                    CornerRadius="4">
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{Binding StatusForeground}"
                                                           Text="{Binding StatusDisplay}" />
                                            </Border>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Title}"
                                                       TextWrapping="Wrap" />
                                        </DockPanel>

                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#64748B"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap" />

                                        <WrapPanel Margin="0,10,0,0">
                                            <Border Margin="0,0,8,8"
                                                    Style="{StaticResource GreenChipBorderStyle}">
                                                <TextBlock Style="{StaticResource GreenChipTextStyle}"
                                                           Text="{Binding SeverityDisplay}" />
                                            </Border>
                                            <Border Margin="0,0,8,8"
                                                    Style="{StaticResource GreenChipBorderStyle}">
                                                <TextBlock Style="{StaticResource GreenChipTextStyle}"
                                                           Text="{Binding PriorityDisplay}" />
                                            </Border>
                                            <TextBlock Margin="0,0,18,0"
                                                       Foreground="#64748B"
                                                       Text="{Binding VersionDisplay}" />
                                            <TextBlock Margin="0,0,18,0"
                                                       Foreground="#64748B"
                                                       Text="{Binding BuildDisplay}" />
                                        </WrapPanel>

                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="#64748B"
                                                       Text="{Binding UpdatedDisplay}"
                                                       TextWrapping="Wrap" />
                                             <Button Grid.Column="1"
                                                     Command="{Binding DataContext.OpenBugDiscussionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     CommandParameter="{Binding}"
                                                     Style="{StaticResource SmallActionButtonStyle}"
                                                     ToolTip="Open bug chat">
                                                 <StackPanel Orientation="Horizontal">
                                                     <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE8BD;" />
                                                     <TextBlock Text="Chat" />
                                                     <Border Margin="6,0,0,0"
                                                             Padding="5,1"
                                                             Background="#DC2626"
                                                             CornerRadius="6"
                                                             Visibility="{Binding DiscussionBadgeVisibility}">
                                                         <TextBlock FontSize="10"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="White"
                                                                    Text="{Binding DiscussionBadgeText}" />
                                                     </Border>
                                                 </StackPanel>
                                             </Button>
                                            <Button Grid.Column="3"
                                                    Command="{Binding DataContext.OpenBugDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Open"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    ToolTip="Open bug details" />
                                        </Grid>

                                        <Border Margin="0,6,0,0"
                                                Style="{StaticResource GreenChipBorderStyle}">
                                            <TextBlock Style="{StaticResource GreenChipTextStyle}"
                                                       Text="{Binding LinkDisplay}" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Panel.ZIndex="20"
                Background="#990F172A"
                Visibility="{Binding NewBugDialogVisibility}">
            <Border Width="560"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="New Bug" />

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="560"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Foreground="#64748B"
                                       Text="Title" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding NewBugTitle, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Description" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="110"
                                     AcceptsReturn="True"
                                     Text="{Binding NewBugDescription, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Foreground="#64748B"
                                               Text="Severity" />
                                    <TextBox Margin="0,6,0,14"
                                             MinHeight="34"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding NewBugSeverity, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Foreground="#64748B"
                                               Text="Priority" />
                                    <TextBox Margin="0,6,0,14"
                                             MinHeight="34"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding NewBugPriority, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Foreground="#64748B"
                                               Text="Found in version" />
                                    <TextBox Margin="0,6,0,14"
                                             MinHeight="34"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding NewBugFoundInVersion, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Foreground="#64748B"
                                               Text="Build number" />
                                    <TextBox Margin="0,6,0,14"
                                             MinHeight="34"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding NewBugBuildNumber, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <shared:CustomFieldValuesEditor DataContext="{Binding NewBugCustomFields}" />

                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#64748B"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                Margin="0,0,10,0"
                                Command="{Binding CloseNewBugDialogCommand}"
                                Content="Cancel"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Close without creating a bug" />
                        <Button MinWidth="100"
                                Command="{Binding CreateBugCommand}"
                                Content="Create"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Create bug" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Panel.ZIndex="20"
                Background="#990F172A"
                Visibility="{Binding BugDetailsDrawerVisibility}">
            <Border Width="720"
                    MaxWidth="820"
                    MaxHeight="760"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CloseBugDetailsCommand}"
                                Content="&#xE8BB;"
                                Style="{StaticResource IconActionButtonStyle}"
                                ToolTip="Close bug details dialog" />
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Bug Details" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Foreground="#64748B"
                                       Text="Title" />
                            <TextBox Margin="0,6,0,12"
                                     MinHeight="34"
                                     Text="{Binding DetailBugTitle, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Description" />
                            <TextBox Margin="0,6,0,12"
                                     MinHeight="130"
                                     AcceptsReturn="True"
                                     Text="{Binding DetailBugDescription, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Foreground="#64748B"
                                               Text="Severity" />
                                    <TextBox Margin="0,6,0,12"
                                             MinHeight="34"
                                             Text="{Binding DetailBugSeverity, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Foreground="#64748B"
                                               Text="Priority" />
                                    <TextBox Margin="0,6,0,12"
                                             MinHeight="34"
                                             Text="{Binding DetailBugPriority, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Foreground="#64748B"
                                               Text="Found in version" />
                                    <TextBox Margin="0,6,0,12"
                                             MinHeight="34"
                                             Text="{Binding DetailBugFoundInVersion, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Foreground="#64748B"
                                               Text="Build number" />
                                    <TextBox Margin="0,6,0,12"
                                             MinHeight="34"
                                             Text="{Binding DetailBugBuildNumber, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Foreground="#64748B"
                                       Text="Status" />
                            <ComboBox Margin="0,6,0,16"
                                      MinHeight="34"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding BugStatuses}"
                                      SelectedItem="{Binding DetailSelectedBugStatus}" />

                            <shared:CustomFieldValuesEditor DataContext="{Binding BugCustomFields}" />

                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#172033"
                                           Text="Attachments" />
                                <Button Grid.Column="1"
                                        Command="{Binding AddBugAttachmentCommand}"
                                        Style="{StaticResource SmallActionButtonStyle}"
                                        ToolTip="Add file to this bug">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE723;" />
                                        <TextBlock Text="Add File" />
                                    </StackPanel>
                                </Button>
                                 <Button Grid.Column="3"
                                         Command="{Binding OpenBugDiscussionCommand}"
                                         Style="{StaticResource SmallActionButtonStyle}"
                                         ToolTip="Open bug chat">
                                     <StackPanel Orientation="Horizontal">
                                         <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE8BD;" />
                                         <TextBlock Text="Chat" />
                                         <Border Margin="6,0,0,0"
                                                 Padding="5,1"
                                                 Background="#DC2626"
                                                 CornerRadius="6"
                                                 Visibility="{Binding SelectedBug.DiscussionBadgeVisibility}">
                                             <TextBlock FontSize="10"
                                                        FontWeight="SemiBold"
                                                        Foreground="White"
                                                        Text="{Binding SelectedBug.DiscussionBadgeText}" />
                                         </Border>
                                     </StackPanel>
                                 </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding BugAttachments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="10"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding OriginalFileName}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               Foreground="#64748B"
                                                               Text="{Binding DetailsDisplay}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Command="{Binding DataContext.OpenBugAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Open"
                                                        Style="{StaticResource SmallActionButtonStyle}"
                                                        ToolTip="Open attachment" />
                                                <Button Grid.Column="3"
                                                        Command="{Binding DataContext.DeleteBugAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE74D;"
                                                        Style="{StaticResource DangerIconActionButtonStyle}"
                                                        ToolTip="Delete attachment" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseBugDetailsCommand}"
                                Content="Cancel"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Close bug details dialog without saving" />
                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding SaveBugDetailsCommand}"
                                Content="Save"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Save bug changes" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Panel.ZIndex="30"
                Background="#220F172A"
                Visibility="{Binding DiscussionDrawerVisibility}">
            <Border Width="460"
                    Padding="20"
                    HorizontalAlignment="Right"
                    Background="#EEF3F8"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CloseDiscussionCommand}"
                                Content="&#xE8BB;"
                                Style="{StaticResource IconActionButtonStyle}"
                                ToolTip="Close chat" />
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="{Binding DiscussionTitle}"
                                   TextWrapping="Wrap" />
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding DiscussionComments}"
                             ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="White"
                                        BorderBrush="#D8E1EC"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal">
                                                <Button Command="{Binding DataContext.EditDiscussionMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE70F;"
                                                        Style="{StaticResource IconActionButtonStyle}"
                                                        ToolTip="Edit message" />
                                                <Button
                                                        Margin="6,0,0,0"
                                                        Command="{Binding DataContext.DeleteDiscussionMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE74D;"
                                                        Style="{StaticResource DangerIconActionButtonStyle}"
                                                        ToolTip="Delete message" />
                                            </StackPanel>
                                            <Border Style="{StaticResource GreenChipBorderStyle}">
                                                <TextBlock Style="{StaticResource GreenChipTextStyle}"
                                                           Text="{Binding HeaderDisplay}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#172033"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,5,0,0"
                                                   Foreground="#94A3B8"
                                                   Text="{Binding EditedDisplay}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            Margin="0,16,0,0"
                            Padding="14"
                            Background="White"
                            BorderBrush="#D8E1EC"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="{Binding DiscussionEditorTitle}" />
                            <TextBox Margin="0,8,0,10"
                                     MinHeight="82"
                                     AcceptsReturn="True"
                                     Background="#F8FAFC"
                                     Text="{Binding DiscussionMessage, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />
                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <Button MinWidth="76"
                                        Margin="0,0,8,0"
                                        Command="{Binding CancelDiscussionEditCommand}"
                                        Content="Clear"
                                        Style="{StaticResource ActionButtonStyle}"
                                        ToolTip="Clear message editor" />
                                <Button MinWidth="110"
                                        Command="{Binding SaveDiscussionMessageCommand}"
                                        Content="{Binding DiscussionSaveButtonText}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        ToolTip="Save message" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
