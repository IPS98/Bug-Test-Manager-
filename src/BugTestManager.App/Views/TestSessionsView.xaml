<UserControl x:Class="BugTestManager.App.Views.TestSessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:BugTestManager.App.Views.Shared">
    <UserControl.Resources>
        <Style x:Key="FullWidthListBoxItemStyle"
               BasedOn="{StaticResource StableListBoxItemStyle}"
               TargetType="ListBoxItem" />

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#172033" />
        </Style>

        <Style x:Key="SmallActionButtonStyle"
               BasedOn="{StaticResource ActionButtonStyle}"
               TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="CheckActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallActionButtonStyle}">
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>

        <Style x:Key="SessionMetaChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding ResultDetailsGapWidth}" />
                <ColumnDefinition Width="{Binding ResultDetailsColumnWidth}" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="22"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Session Results" />
                            <Border Margin="0,6,0,0"
                                    Style="{StaticResource GreenChipBorderStyle}"
                                    Visibility="{Binding SessionWorkspaceVisibility}">
                                <TextBlock FontSize="14"
                                           Style="{StaticResource GreenChipTextStyle}"
                                           Text="{Binding SelectedSession.Name}" />
                            </Border>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  Width="360"
                                  MinHeight="34"
                                  DisplayMemberPath="SelectorDisplay"
                                  ItemsSource="{Binding Sessions}"
                                  SelectedItem="{Binding SelectedSession}"
                                  ToolTip="Select created test session" />
                        <Button Grid.Column="3"
                                Command="{Binding ShowNewSessionDialogCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Create a new test session">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                <TextBlock Text="New Session" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="5"
                                Command="{Binding ShowTemplateSyncDialogCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Save session structure changes back to a template">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE74E;" />
                                <TextBlock Text="Save Template" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="7"
                                Command="{Binding ShowDeleteSessionDialogCommand}"
                                Content="&#xE74D;"
                                Style="{StaticResource DangerIconActionButtonStyle}"
                                ToolTip="Delete selected test session" />

                        <WrapPanel Grid.Row="1"
                                   Grid.ColumnSpan="8"
                                   Margin="0,10,0,0"
                                   Visibility="{Binding SessionWorkspaceVisibility}">
                            <Border Style="{StaticResource SessionMetaChipStyle}">
                                <TextBlock Foreground="#64748B"
                                           Text="{Binding SelectedSession.VersionDisplay}" />
                            </Border>
                            <Border Style="{StaticResource SessionMetaChipStyle}">
                                <TextBlock Foreground="#64748B"
                                           Text="{Binding SelectedSession.BuildDisplay}" />
                            </Border>
                            <Border Style="{StaticResource SessionMetaChipStyle}">
                                <TextBlock Foreground="#64748B"
                                           Text="{Binding SelectedSession.RevisionHeaderDisplay}" />
                            </Border>
                            <Border Style="{StaticResource SessionMetaChipStyle}">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="#172033"
                                           Text="{Binding ResultSummary}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </WrapPanel>
                    </Grid>

                    <Grid>
                        <Grid Visibility="{Binding SessionWorkspaceVisibility}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top"
                                           Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right"
                                            Command="{Binding ShowCreateManualSectionDialogCommand}"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            ToolTip="Add manual section">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                            <TextBlock Text="Add" />
                                        </StackPanel>
                                    </Button>
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Text="Sections" />
                                </DockPanel>
                                <ListBox ItemsSource="{Binding Sections}"
                                         SelectedItem="{Binding SelectedSection}"
                                         ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                                         BorderThickness="0"
                                         ScrollViewer.CanContentScroll="False"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,4,0,10"
                                                    Style="{StaticResource SelectableCardBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding Name}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="#64748B"
                                                               Text="{Binding CategoryDisplay}"
                                                               TextWrapping="Wrap" />
                                                    <Border Margin="0,6,0,0"
                                                            Style="{StaticResource GreenChipBorderStyle}">
                                                        <TextBlock Style="{StaticResource GreenChipTextStyle}"
                                                                   Text="{Binding SizeDisplay}" />
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                        <DockPanel Grid.Column="2">
                            <Grid DockPanel.Dock="Top"
                                  Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Text="Test Cases" />
                                <Button Grid.Column="1"
                                        Command="{Binding ShowCreateManualTestCaseDialogCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        ToolTip="Add manual test case">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                        <TextBlock Text="Add Case" />
                                    </StackPanel>
                                </Button>
                                <ComboBox Grid.Column="3"
                                          MinHeight="32"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding ResultStatusFilters}"
                                          SelectedItem="{Binding SelectedResultStatusFilter}" />
                            </Grid>
                            <ListBox ItemsSource="{Binding FilteredTestCases}"
                                     SelectedItem="{Binding SelectedTestCase}"
                                     ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                                     BorderThickness="0"
                                     ScrollViewer.CanContentScroll="False"
                                     VirtualizingPanel.IsVirtualizing="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4,0,14"
                                                Style="{StaticResource SelectableCardBorderStyle}">
                                            <StackPanel>
                                                <DockPanel LastChildFill="True">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Command="{Binding DataContext.ShowEditTestCaseResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Update Case"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Update this test case result" />
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Command="{Binding DataContext.ShowCreateManualCheckDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Add a manual check">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                                            <TextBlock Text="Check" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Command="{Binding DataContext.ShowTestCaseDiscussionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Open test case chat">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE8BD;" />
                                                            <TextBlock Text="Chat" />
                                                            <Border Margin="6,0,0,0"
                                                                    Padding="5,1"
                                                                    Background="#DC2626"
                                                                    CornerRadius="6"
                                                                    Visibility="{Binding DiscussionBadgeVisibility}">
                                                                <TextBlock FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="White"
                                                                           Text="{Binding DiscussionBadgeText}" />
                                                            </Border>
                                                        </StackPanel>
                                                    </Button>
                                                    <Border DockPanel.Dock="Right"
                                                            Padding="8,3"
                                                            Background="{Binding StatusBackground}"
                                                            CornerRadius="4">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusForeground}"
                                                                   Text="{Binding StatusDisplay}" />
                                                    </Border>
                                                    <Border DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Style="{StaticResource InfoChipBorderStyle}"
                                                            ToolTip="{Binding LinkedBugSummaryDisplay}"
                                                            Visibility="{Binding LinkedBugBadgeVisibility}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xEBE8;" />
                                                            <TextBlock Style="{StaticResource InfoChipTextStyle}"
                                                                       Text="{Binding LinkedBugCountDisplay}" />
                                                        </StackPanel>
                                                    </Border>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding Title}"
                                                               TextWrapping="Wrap" />
                                                </DockPanel>

                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#64748B"
                                                           Text="{Binding ExpectedResult}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#475569"
                                                           Text="{Binding CommentDisplay}"
                                                           TextWrapping="Wrap" />

                                                <Border Margin="0,12,0,0"
                                                        Padding="12"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="#172033"
                                                                   Text="{Binding CheckCountDisplay}" />
                                                        <ItemsControl Margin="0,8,0,0"
                                                                      ItemsSource="{Binding Steps}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,0,0,10">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="34" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <Border Width="24"
                                                                                Height="24"
                                                                                Background="#E7F6EF"
                                                                                CornerRadius="12">
                                                                            <TextBlock HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="#256D5A"
                                                                                       Text="{Binding SortOrder}" />
                                                                        </Border>

                                                                        <StackPanel Grid.Column="1">
                                                                            <DockPanel LastChildFill="True">
                                                                                <Button DockPanel.Dock="Right"
                                                                                        Command="{Binding DataContext.ShowEditTestStepResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        CommandParameter="{Binding}"
                                                                                        Content="Update"
                                                                                        Style="{StaticResource CheckActionButtonStyle}"
                                                                                        ToolTip="Update this check result" />
                                                                                <Button DockPanel.Dock="Right"
                                                                                        Command="{Binding DataContext.ShowTestStepDiscussionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        CommandParameter="{Binding}"
                                                                                        Style="{StaticResource CheckActionButtonStyle}"
                                                                                        ToolTip="Open check chat">
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE8BD;" />
                                                                                        <TextBlock Text="Chat" />
                                                                                        <Border Margin="6,0,0,0"
                                                                                                Padding="5,1"
                                                                                                Background="#DC2626"
                                                                                                CornerRadius="6"
                                                                                                Visibility="{Binding DiscussionBadgeVisibility}">
                                                                                            <TextBlock FontSize="10"
                                                                                                       FontWeight="SemiBold"
                                                                                                       Foreground="White"
                                                                                                       Text="{Binding DiscussionBadgeText}" />
                                                                                        </Border>
                                                                                    </StackPanel>
                                                                                </Button>
                                                                <Border DockPanel.Dock="Right"
                                                                        Padding="8,3"
                                                                        Background="{Binding StatusBackground}"
                                                                        CornerRadius="4">
                                                                    <TextBlock FontWeight="SemiBold"
                                                                               Foreground="{Binding StatusForeground}"
                                                                               Text="{Binding StatusDisplay}" />
                                                                </Border>
                                                                <Border DockPanel.Dock="Right"
                                                                        Margin="10,0,0,0"
                                                                        Style="{StaticResource InfoChipBorderStyle}"
                                                                        ToolTip="{Binding LinkedBugSummaryDisplay}"
                                                                        Visibility="{Binding LinkedBugBadgeVisibility}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xEBE8;" />
                                                                        <TextBlock Style="{StaticResource InfoChipTextStyle}"
                                                                                   Text="{Binding LinkedBugCountDisplay}" />
                                                                    </StackPanel>
                                                                </Border>
                                                                <TextBlock FontWeight="SemiBold"
                                                                           Text="{Binding CheckText}"
                                                                           TextWrapping="Wrap" />
                                                                            </DockPanel>
                                                                            <TextBlock Margin="0,5,0,0"
                                                                                       Foreground="#64748B"
                                                                                       Text="{Binding ExpectedResult}"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Margin="0,5,0,0"
                                                                                       Foreground="#475569"
                                                                                       Text="{Binding CommentDisplay}"
                                                                                       TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                        </Grid>

                        <Border Padding="28"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding EmptyStateVisibility}">
                            <StackPanel Width="420"
                                        HorizontalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="34"
                                           Foreground="#256D5A"
                                           Text="&#xE9D9;" />
                                <TextBlock Margin="0,14,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#172033"
                                           Text="No test sessions yet" />
                                <TextBlock Margin="0,8,0,18"
                                           HorizontalAlignment="Center"
                                           Foreground="#64748B"
                                           Text="Create your first test session to start testing."
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <Button HorizontalAlignment="Center"
                                        Command="{Binding ShowNewSessionDialogCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        ToolTip="Create a new test session">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                        <TextBlock Text="New Test Session" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="18"
                    Background="White"
                    CornerRadius="8"
                    Visibility="{Binding ResultDialogOverlayVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Command="{Binding ShowLinkedBugDialogCommand}"
                                    Style="{StaticResource SmallActionButtonStyle}"
                                    ToolTip="Create or view a linked bug">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xEBE8;" />
                                    <TextBlock Text="{Binding ResultLinkedBugButtonText}" />
                                    <Border Margin="6,0,0,0"
                                            Padding="5,1"
                                            Background="#1D4ED8"
                                            CornerRadius="6"
                                            Visibility="{Binding ResultLinkedBugBadgeVisibility}">
                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Text="Linked" />
                                    </Border>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,0"
                                    Command="{Binding ShowCurrentResultDiscussionCommand}"
                                    Style="{StaticResource SmallActionButtonStyle}"
                                    ToolTip="Open result chat">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE8BD;" />
                                    <TextBlock Text="Chat" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding CloseResultDialogCommand}"
                                    Content="&#xE8BB;"
                                    Style="{StaticResource IconActionButtonStyle}"
                                    ToolTip="Close details panel" />
                        </StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="{Binding ResultDialogTitle}"
                                   TextWrapping="Wrap" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Foreground="#64748B"
                                       Text="Status" />
                            <ComboBox Margin="0,6,0,14"
                                      MinHeight="34"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding ResultStatuses}"
                                      SelectedItem="{Binding SelectedResultStatus}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Comment" />
                            <TextBox Margin="0,6,0,0"
                                     MinHeight="110"
                                     AcceptsReturn="True"
                                     Text="{Binding ResultComment, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />

                            <shared:CustomFieldValuesEditor DataContext="{Binding ResultCustomFields}" />

                            <Grid Margin="0,18,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="#172033"
                                           Text="Attachments" />
                                <Button Grid.Column="1"
                                        Command="{Binding AddAttachmentCommand}"
                                        Style="{StaticResource SmallActionButtonStyle}"
                                        ToolTip="Add attachment to this result">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE723;" />
                                        <TextBlock Text="Add" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ResultAttachments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="10"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="60"
                                                        Height="46"
                                                        Background="#F1F5F9"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                    <Image Source="{Binding AbsolutePath}"
                                                           Stretch="UniformToFill">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            Margin="0,0,10,0">
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding OriginalFileName}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               Foreground="#64748B"
                                                               Text="{Binding DetailsDisplay}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Orientation="Horizontal">
                                                    <Button Margin="0,0,8,0"
                                                            Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Open"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Open attachment" />
                                                    <Button Command="{Binding DataContext.DeleteAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="&#xE74D;"
                                                            Style="{StaticResource DangerIconActionButtonStyle}"
                                                            ToolTip="Delete attachment" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="4"
                               Margin="0,0,0,14"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="5"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                Margin="0,0,10,0"
                                Command="{Binding CloseResultDialogCommand}"
                                Content="Cancel"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Close details panel without saving" />
                        <Button MinWidth="92"
                                Command="{Binding SaveResultCommand}"
                                Content="Save"
                                IsDefault="True"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Save result changes" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Panel.ZIndex="24"
                Background="#990F172A"
                Visibility="{Binding LinkedBugDialogVisibility}">
            <Border Width="520"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CloseLinkedBugDialogCommand}"
                                Content="&#xE8BB;"
                                Style="{StaticResource IconActionButtonStyle}"
                                ToolTip="Close linked bug dialog" />
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Linked Bug" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="420"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Padding="10"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <TextBlock Foreground="#64748B"
                                           Text="{Binding LinkedBugTargetDisplay}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <TextBlock Margin="0,14,0,6"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Existing linked bugs"
                                       Visibility="{Binding ResultLinkedBugListVisibility}" />
                            <ItemsControl ItemsSource="{Binding ResultLinkedBugs}"
                                          Visibility="{Binding ResultLinkedBugListVisibility}">
                                <ItemsControl.ItemTemplate>
