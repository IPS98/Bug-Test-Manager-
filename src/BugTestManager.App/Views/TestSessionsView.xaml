<UserControl x:Class="BugTestManager.App.Views.TestSessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:BugTestManager.App.Views.Shared">
    <UserControl.Resources>
        <Style x:Key="FullWidthListBoxItemStyle"
               BasedOn="{StaticResource StableListBoxItemStyle}"
               TargetType="ListBoxItem" />

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#172033" />
        </Style>

        <Style x:Key="SmallActionButtonStyle"
               BasedOn="{StaticResource ActionButtonStyle}"
               TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="CheckActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallActionButtonStyle}">
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>

        <Style x:Key="SessionMetaChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding ResultDetailsGapWidth}" />
                <ColumnDefinition Width="{Binding ResultDetailsColumnWidth}" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="22"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Session Results" />
                            <Border Margin="0,6,0,0"
                                    Style="{StaticResource GreenChipBorderStyle}">
                                <TextBlock FontSize="14"
                                           Style="{StaticResource GreenChipTextStyle}"
                                           Text="{Binding SelectedSession.Name}" />
                            </Border>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  Width="360"
                                  MinHeight="34"
                                  DisplayMemberPath="SelectorDisplay"
                                  ItemsSource="{Binding Sessions}"
                                  SelectedItem="{Binding SelectedSession}"
                                  ToolTip="Select created test session" />
                        <Button Grid.Column="3"
                                Command="{Binding ShowNewSessionDialogCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Create a new test session">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                <TextBlock Text="New Session" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="5"
                                Command="{Binding ShowDeleteSessionDialogCommand}"
                                Content="&#xE74D;"
                                Style="{StaticResource DangerIconActionButtonStyle}"
                                ToolTip="Delete selected test session" />

                        <WrapPanel Grid.Row="1"
                                   Grid.ColumnSpan="6"
                                   Margin="0,10,0,0">
                            <Border Style="{StaticResource SessionMetaChipStyle}">
                                <TextBlock Foreground="#64748B"
                                           Text="{Binding SelectedSession.VersionDisplay}" />
                            </Border>
                            <Border Style="{StaticResource SessionMetaChipStyle}">
                                <TextBlock Foreground="#64748B"
                                           Text="{Binding SelectedSession.BuildDisplay}" />
                            </Border>
                            <Border Style="{StaticResource SessionMetaChipStyle}">
                                <TextBlock Foreground="#64748B"
                                           Text="{Binding SelectedSession.RevisionHeaderDisplay}" />
                            </Border>
                            <Border Style="{StaticResource SessionMetaChipStyle}">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="#172033"
                                           Text="{Binding ResultSummary}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </WrapPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top"
                                       Margin="0,0,0,12">
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding ShowCreateManualSectionDialogCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        ToolTip="Add manual section">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                        <TextBlock Text="Add" />
                                    </StackPanel>
                                </Button>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Text="Sections" />
                            </DockPanel>
                            <ListBox ItemsSource="{Binding Sections}"
                                     SelectedItem="{Binding SelectedSection}"
                                     ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                                     BorderThickness="0"
                                     ScrollViewer.CanContentScroll="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4,0,10">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Name}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#64748B"
                                                       Text="{Binding CategoryDisplay}"
                                                       TextWrapping="Wrap" />
                                            <Border Margin="0,6,0,0"
                                                    Style="{StaticResource GreenChipBorderStyle}">
                                                <TextBlock Style="{StaticResource GreenChipTextStyle}"
                                                           Text="{Binding SizeDisplay}" />
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <DockPanel Grid.Column="2">
                            <Grid DockPanel.Dock="Top"
                                  Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Text="Test Cases" />
                                <Button Grid.Column="1"
                                        Command="{Binding ShowCreateManualTestCaseDialogCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        ToolTip="Add manual test case">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                        <TextBlock Text="Add Case" />
                                    </StackPanel>
                                </Button>
                                <ComboBox Grid.Column="3"
                                          MinHeight="32"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding ResultStatusFilters}"
                                          SelectedItem="{Binding SelectedResultStatusFilter}" />
                            </Grid>
                            <ListBox ItemsSource="{Binding FilteredTestCases}"
                                     SelectedItem="{Binding SelectedTestCase}"
                                     ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                                     BorderThickness="0"
                                     ScrollViewer.CanContentScroll="False"
                                     VirtualizingPanel.IsVirtualizing="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4,0,14"
                                                Padding="14"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <DockPanel LastChildFill="True">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Command="{Binding DataContext.ShowEditTestCaseResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Update Case"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Update this test case result" />
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Command="{Binding DataContext.ShowCreateManualCheckDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Add a manual check">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE710;" />
                                                            <TextBlock Text="Check" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Command="{Binding DataContext.ShowTestCaseDiscussionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Open test case chat">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE8BD;" />
                                                            <TextBlock Text="Chat" />
                                                            <Border Margin="6,0,0,0"
                                                                    Padding="5,1"
                                                                    Background="#DC2626"
                                                                    CornerRadius="6"
                                                                    Visibility="{Binding DiscussionBadgeVisibility}">
                                                                <TextBlock FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="White"
                                                                           Text="{Binding DiscussionBadgeText}" />
                                                            </Border>
                                                        </StackPanel>
                                                    </Button>
                                                    <Border DockPanel.Dock="Right"
                                                            Padding="8,3"
                                                            Background="{Binding StatusBackground}"
                                                            CornerRadius="4">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusForeground}"
                                                                   Text="{Binding StatusDisplay}" />
                                                    </Border>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding Title}"
                                                               TextWrapping="Wrap" />
                                                </DockPanel>

                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#64748B"
                                                           Text="{Binding ExpectedResult}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#475569"
                                                           Text="{Binding CommentDisplay}"
                                                           TextWrapping="Wrap" />

                                                <Border Margin="0,12,0,0"
                                                        Padding="12"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="#172033"
                                                                   Text="{Binding CheckCountDisplay}" />
                                                        <ItemsControl Margin="0,8,0,0"
                                                                      ItemsSource="{Binding Steps}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,0,0,10">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="34" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <Border Width="24"
                                                                                Height="24"
                                                                                Background="#E7F6EF"
                                                                                CornerRadius="12">
                                                                            <TextBlock HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="#256D5A"
                                                                                       Text="{Binding SortOrder}" />
                                                                        </Border>

                                                                        <StackPanel Grid.Column="1">
                                                                            <DockPanel LastChildFill="True">
                                                                                <Button DockPanel.Dock="Right"
                                                                                        Command="{Binding DataContext.ShowEditTestStepResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        CommandParameter="{Binding}"
                                                                                        Content="Update"
                                                                                        Style="{StaticResource CheckActionButtonStyle}"
                                                                                        ToolTip="Update this check result" />
                                                                                <Button DockPanel.Dock="Right"
                                                                                        Command="{Binding DataContext.ShowTestStepDiscussionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        CommandParameter="{Binding}"
                                                                                        Style="{StaticResource CheckActionButtonStyle}"
                                                                                        ToolTip="Open check chat">
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE8BD;" />
                                                                                        <TextBlock Text="Chat" />
                                                                                        <Border Margin="6,0,0,0"
                                                                                                Padding="5,1"
                                                                                                Background="#DC2626"
                                                                                                CornerRadius="6"
                                                                                                Visibility="{Binding DiscussionBadgeVisibility}">
                                                                                            <TextBlock FontSize="10"
                                                                                                       FontWeight="SemiBold"
                                                                                                       Foreground="White"
                                                                                                       Text="{Binding DiscussionBadgeText}" />
                                                                                        </Border>
                                                                                    </StackPanel>
                                                                                </Button>
                                                                                <Border DockPanel.Dock="Right"
                                                                                        Padding="8,3"
                                                                                        Background="{Binding StatusBackground}"
                                                                                        CornerRadius="4">
                                                                                    <TextBlock FontWeight="SemiBold"
                                                                                               Foreground="{Binding StatusForeground}"
                                                                                               Text="{Binding StatusDisplay}" />
                                                                                </Border>
                                                                                <TextBlock FontWeight="SemiBold"
                                                                                           Text="{Binding CheckText}"
                                                                                           TextWrapping="Wrap" />
                                                                            </DockPanel>
                                                                            <TextBlock Margin="0,5,0,0"
                                                                                       Foreground="#64748B"
                                                                                       Text="{Binding ExpectedResult}"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Margin="0,5,0,0"
                                                                                       Foreground="#475569"
                                                                                       Text="{Binding CommentDisplay}"
                                                                                       TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="18"
                    Background="White"
                    CornerRadius="8"
                    Visibility="{Binding ResultDialogOverlayVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Command="{Binding ShowCurrentResultDiscussionCommand}"
                                    Style="{StaticResource SmallActionButtonStyle}"
                                    ToolTip="Open result chat">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE8BD;" />
                                    <TextBlock Text="Chat" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding CloseResultDialogCommand}"
                                    Content="&#xE8BB;"
                                    Style="{StaticResource IconActionButtonStyle}"
                                    ToolTip="Close details panel" />
                        </StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="{Binding ResultDialogTitle}"
                                   TextWrapping="Wrap" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Foreground="#64748B"
                                       Text="Status" />
                            <ComboBox Margin="0,6,0,14"
                                      MinHeight="34"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding ResultStatuses}"
                                      SelectedItem="{Binding SelectedResultStatus}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Comment" />
                            <TextBox Margin="0,6,0,0"
                                     MinHeight="110"
                                     AcceptsReturn="True"
                                     Text="{Binding ResultComment, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />

                            <shared:CustomFieldValuesEditor DataContext="{Binding ResultCustomFields}" />

                            <Grid Margin="0,18,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="#172033"
                                           Text="Attachments" />
                                <Button Grid.Column="1"
                                        Command="{Binding AddAttachmentCommand}"
                                        Style="{StaticResource SmallActionButtonStyle}"
                                        ToolTip="Add attachment to this result">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE723;" />
                                        <TextBlock Text="Add" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ResultAttachments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="10"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="60"
                                                        Height="46"
                                                        Background="#F1F5F9"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                    <Image Source="{Binding AbsolutePath}"
                                                           Stretch="UniformToFill">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            Margin="0,0,10,0">
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding OriginalFileName}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               Foreground="#64748B"
                                                               Text="{Binding DetailsDisplay}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Orientation="Horizontal">
                                                    <Button Margin="0,0,8,0"
                                                            Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Open"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Open attachment" />
                                                    <Button Command="{Binding DataContext.DeleteAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="&#xE74D;"
                                                            Style="{StaticResource DangerIconActionButtonStyle}"
                                                            ToolTip="Delete attachment" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Margin="0,18,0,6"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Linked Bug" />
                            <TextBlock Foreground="#64748B"
                                       Text="{Binding LinkedBugTargetDisplay}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,10,0,6"
                                       Foreground="#64748B"
                                       Text="Bug title" />
                            <TextBox MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding LinkedBugTitle, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,10,0,6"
                                       Foreground="#64748B"
                                       Text="Bug description" />
                            <TextBox MinHeight="80"
                                     AcceptsReturn="True"
                                     Text="{Binding LinkedBugDescription, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />

                            <Button Margin="0,12,0,0"
                                    HorizontalAlignment="Right"
                                    Command="{Binding CreateLinkedBugCommand}"
                                    Content="Create Linked Bug"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTip="Create bug linked to this result" />
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="4"
                               Margin="0,0,0,14"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="5"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                Margin="0,0,10,0"
                                Command="{Binding CloseResultDialogCommand}"
                                Content="Cancel"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Close details panel without saving" />
                        <Button MinWidth="92"
                                Command="{Binding SaveResultCommand}"
                                Content="Save"
                                IsDefault="True"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Save result changes" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Background="#990F172A"
                Visibility="{Binding NewSessionDialogVisibility}">
            <Border Width="540"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="New Test Session" />

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="500"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Foreground="#64748B"
                                       Text="Template source" />
                            <ComboBox Margin="0,6,0,14"
                                      MinHeight="34"
                                      DisplayMemberPath="Name"
                                      ItemsSource="{Binding TestSuites}"
                                      SelectedItem="{Binding SelectedTestSuite}" />

                            <StackPanel Visibility="{Binding RevisionPickerVisibility}">
                                <TextBlock Foreground="#64748B"
                                           Text="Revision" />
                                <ComboBox Margin="0,6,0,14"
                                          MinHeight="34"
                                          DisplayMemberPath="Name"
                                          ItemsSource="{Binding Revisions}"
                                          SelectedItem="{Binding SelectedRevision}" />
                            </StackPanel>

                            <TextBlock Foreground="#64748B"
                                       Text="Session name" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding NewSessionName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Tested version" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding TestedVersion, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Build number" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding BuildNumber, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Notes" />
                            <TextBox Margin="0,6,0,0"
                                     MinHeight="90"
                                     AcceptsReturn="True"
                                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />
                            <TextBlock Margin="0,12,0,0"
                                       Foreground="#64748B"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseNewSessionDialogCommand}"
                                Content="Cancel"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Close this dialog without creating a session" />
                        <Button MinWidth="120"
                                MinHeight="34"
                                Command="{Binding CreateSessionCommand}"
                                Content="Create Session"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Create test session" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Background="#990F172A"
                Visibility="{Binding DeleteSessionDialogVisibility}">
            <Border Width="500"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="{Binding DeleteSessionTitle}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2"
                               Foreground="#64748B"
                               Text="{Binding DeleteSessionWarning}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="4"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseDeleteSessionDialogCommand}"
                                Content="Cancel"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Cancel session delete" />
                        <Button MinWidth="120"
                                MinHeight="34"
                                Command="{Binding ConfirmDeleteSessionCommand}"
                                Content="Delete Session"
                                Style="{StaticResource DangerActionButtonStyle}"
                                ToolTip="Delete this test session" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Background="#990F172A"
                Visibility="{Binding ManualDialogOverlayVisibility}">
            <Border Width="520"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="{Binding ManualDialogTitle}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="2">
                        <TextBlock Foreground="#64748B"
                                   Text="Name or title" />
                        <TextBox Margin="0,6,0,14"
                                 MinHeight="34"
                                 Text="{Binding ManualItemName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Foreground="#64748B"
                                   Text="Category, expected result, or details" />
                        <TextBox Margin="0,6,0,0"
                                 MinHeight="110"
                                 AcceptsReturn="True"
                                 Text="{Binding ManualItemDescription, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock Grid.Row="4"
                               Margin="0,0,0,14"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="5"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseManualItemDialogCommand}"
                                Content="Cancel"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Close this dialog without saving" />
                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding SaveManualItemCommand}"
                                Content="Save"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Save manual item" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Visibility="Collapsed">
            <Border Width="560"
                    MaxWidth="620"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding ShowCurrentResultDiscussionCommand}"
                                Style="{StaticResource SmallActionButtonStyle}"
                                ToolTip="Open result chat">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE8BD;" />
                                <TextBlock Text="Chat" />
                            </StackPanel>
                        </Button>
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="{Binding ResultDialogTitle}"
                                   TextWrapping="Wrap" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="420"
                                  VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Foreground="#64748B"
                                   Text="Status" />
                        <ComboBox Margin="0,6,0,14"
                                  MinHeight="34"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding ResultStatuses}"
                                  SelectedItem="{Binding SelectedResultStatus}" />

                        <TextBlock Foreground="#64748B"
                                   Text="Comment" />
                        <TextBox Margin="0,6,0,0"
                                 MinHeight="110"
                                 AcceptsReturn="True"
                                 Text="{Binding ResultComment, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" />

                        <shared:CustomFieldValuesEditor DataContext="{Binding ResultCustomFields}" />

                        <Grid Margin="0,18,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Attachments" />
                            <Button Grid.Column="1"
                                    Command="{Binding AddAttachmentCommand}"
                                    Style="{StaticResource SmallActionButtonStyle}"
                                    ToolTip="Add attachment to this result">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE723;" />
                                    <TextBlock Text="Add Attachment" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ResultAttachments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="84" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="72"
                                                    Height="54"
                                                    Background="#F1F5F9"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                <Image Source="{Binding AbsolutePath}"
                                                       Stretch="UniformToFill">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Margin="0,0,12,0">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding OriginalFileName}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,3,0,0"
                                                           Foreground="#64748B"
                                                           Text="{Binding DetailsDisplay}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal">
                                                <Button Margin="0,0,8,0"
                                                        Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Open"
                                                        Style="{StaticResource SmallActionButtonStyle}"
                                                        ToolTip="Open attachment" />
                                                <Button Command="{Binding DataContext.DeleteAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE74D;"
                                                        Style="{StaticResource DangerIconActionButtonStyle}"
                                                        ToolTip="Delete attachment" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,18,0,6"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Linked Bug" />
                        <TextBlock Foreground="#64748B"
                                   Text="{Binding LinkedBugTargetDisplay}"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,10,0,6"
                                   Foreground="#64748B"
                                   Text="Bug title" />
                        <TextBox MinHeight="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding LinkedBugTitle, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,6"
                                   Foreground="#64748B"
                                   Text="Bug description" />
                        <TextBox MinHeight="80"
                                 AcceptsReturn="True"
                                 Text="{Binding LinkedBugDescription, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" />

                        <Button Margin="0,12,0,0"
                                MinHeight="34"
                                HorizontalAlignment="Right"
                                Command="{Binding CreateLinkedBugCommand}"
                                Content="Create Linked Bug"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Create bug linked to this result" />
                    </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="4"
                               Margin="0,0,0,14"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="5"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseResultDialogCommand}"
                                Content="Cancel"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Close result dialog without saving" />
                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding SaveResultCommand}"
                                Content="Save"
                                IsDefault="True"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Save result changes" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Panel.ZIndex="30"
                Background="#220F172A"
                Visibility="{Binding DiscussionDrawerVisibility}">
            <Border Width="460"
                    Padding="20"
                    HorizontalAlignment="Right"
                    Background="#EEF3F8"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CloseDiscussionCommand}"
                                Content="&#xE8BB;"
                                Style="{StaticResource IconActionButtonStyle}"
                                ToolTip="Close chat" />
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="{Binding DiscussionTitle}"
                                   TextWrapping="Wrap" />
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding DiscussionComments}"
                             ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="White"
                                        BorderBrush="#D8E1EC"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal">
                                                <Button Command="{Binding DataContext.EditDiscussionMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE70F;"
                                                        Style="{StaticResource IconActionButtonStyle}"
                                                        ToolTip="Edit message" />
                                                <Button
                                                        Margin="6,0,0,0"
                                                        Command="{Binding DataContext.DeleteDiscussionMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE74D;"
                                                        Style="{StaticResource DangerIconActionButtonStyle}"
                                                        ToolTip="Delete message" />
                                            </StackPanel>
                                            <Border Style="{StaticResource GreenChipBorderStyle}">
                                                <TextBlock Style="{StaticResource GreenChipTextStyle}"
                                                           Text="{Binding HeaderDisplay}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#172033"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,5,0,0"
                                                   Foreground="#94A3B8"
                                                   Text="{Binding EditedDisplay}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            Margin="0,16,0,0"
                            Padding="14"
                            Background="White"
                            BorderBrush="#D8E1EC"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="{Binding DiscussionEditorTitle}" />
                            <TextBox Margin="0,8,0,10"
                                     MinHeight="82"
                                     AcceptsReturn="True"
                                     Background="#F8FAFC"
                                     Text="{Binding DiscussionMessage, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />
                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <Button MinWidth="76"
                                        Margin="0,0,8,0"
                                        Command="{Binding CancelDiscussionEditCommand}"
                                        Content="Clear"
                                        Style="{StaticResource ActionButtonStyle}"
                                        ToolTip="Clear message editor" />
                                <Button MinWidth="110"
                                        Command="{Binding SaveDiscussionMessageCommand}"
                                        Content="{Binding DiscussionSaveButtonText}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        ToolTip="Save message" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
