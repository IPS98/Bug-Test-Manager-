<UserControl x:Class="BugTestManager.App.Views.TestSessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FullWidthListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#172033" />
        </Style>

        <Style x:Key="SmallActionButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="CheckActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallActionButtonStyle}">
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18"
                    Background="White"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="New Test Session" />

                    <TextBlock Margin="0,18,0,6"
                               Foreground="#64748B"
                               Text="Template source" />
                    <ComboBox MinHeight="34"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding TestSuites}"
                              SelectedItem="{Binding SelectedTestSuite}" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Revision" />
                    <ComboBox MinHeight="34"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding Revisions}"
                              SelectedItem="{Binding SelectedRevision}" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Session name" />
                    <TextBox MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewSessionName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Tested version" />
                    <TextBox MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding TestedVersion, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Build number" />
                    <TextBox MinHeight="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding BuildNumber, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,14,0,6"
                               Foreground="#64748B"
                               Text="Notes" />
                    <TextBox MinHeight="78"
                             AcceptsReturn="True"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" />

                    <Button Margin="0,18,0,0"
                            MinHeight="36"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CreateSessionCommand}"
                            Content="Create Session" />

                    <TextBlock Margin="0,14,0,0"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="18"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,14"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="Created Sessions" />

                    <ListBox ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding SelectedSession}"
                             ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,12">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding TestSuiteName}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding RevisionDisplay}" />
                                    <TextBlock Margin="0,6,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#256D5A"
                                               Text="{Binding SizeDisplay}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding CreatedAtDisplay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="4"
                    Padding="18"
                    Background="White"
                    CornerRadius="8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Margin="0,0,0,16">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Session Results" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#256D5A"
                                   Text="{Binding SelectedSession.Name}"
                                   TextWrapping="Wrap" />
                        <WrapPanel Margin="0,8,0,0">
                            <TextBlock Margin="0,0,18,0"
                                       Foreground="#64748B"
                                       Text="{Binding SelectedSession.VersionDisplay}" />
                            <TextBlock Margin="0,0,18,0"
                                       Foreground="#64748B"
                                       Text="{Binding SelectedSession.BuildDisplay}" />
                            <TextBlock Margin="0,0,18,0"
                                       Foreground="#64748B"
                                       Text="{Binding SelectedSession.RevisionHeaderDisplay}" />
                        </WrapPanel>
                        <TextBlock Margin="0,8,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="{Binding ResultSummary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top"
                                       Margin="0,0,0,12">
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding ShowCreateManualSectionDialogCommand}"
                                        Content="+ Add"
                                        Style="{StaticResource SmallActionButtonStyle}" />
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Text="Sections" />
                            </DockPanel>
                            <ListBox ItemsSource="{Binding Sections}"
                                     SelectedItem="{Binding SelectedSection}"
                                     ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4,0,10">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Name}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#64748B"
                                                       Text="{Binding CategoryDisplay}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="#256D5A"
                                                       Text="{Binding SizeDisplay}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <DockPanel Grid.Column="2">
                            <Grid DockPanel.Dock="Top"
                                  Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Text="Test Cases" />
                                <Button Grid.Column="1"
                                        Command="{Binding ShowCreateManualTestCaseDialogCommand}"
                                        Content="+ Add Case"
                                        Style="{StaticResource SmallActionButtonStyle}" />
                                <ComboBox Grid.Column="3"
                                          MinHeight="32"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding ResultStatusFilters}"
                                          SelectedItem="{Binding SelectedResultStatusFilter}" />
                            </Grid>
                            <ListBox ItemsSource="{Binding FilteredTestCases}"
                                     SelectedItem="{Binding SelectedTestCase}"
                                     ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4,0,14"
                                                Padding="14"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <DockPanel LastChildFill="True">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Command="{Binding DataContext.ShowEditTestCaseResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Update Case"
                                                            Style="{StaticResource SmallActionButtonStyle}" />
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Command="{Binding DataContext.ShowCreateManualCheckDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="+ Check"
                                                            Style="{StaticResource SmallActionButtonStyle}" />
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="12,0,0,0"
                                                            Command="{Binding DataContext.ShowTestCaseDiscussionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Chat"
                                                            Style="{StaticResource SmallActionButtonStyle}" />
                                                    <Border DockPanel.Dock="Right"
                                                            Padding="8,3"
                                                            Background="{Binding StatusBackground}"
                                                            CornerRadius="4">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusForeground}"
                                                                   Text="{Binding StatusDisplay}" />
                                                    </Border>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding Title}"
                                                               TextWrapping="Wrap" />
                                                </DockPanel>

                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#64748B"
                                                           Text="{Binding ExpectedResult}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#475569"
                                                           Text="{Binding CommentDisplay}"
                                                           TextWrapping="Wrap" />

                                                <Border Margin="0,12,0,0"
                                                        Padding="12"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="#172033"
                                                                   Text="{Binding CheckCountDisplay}" />
                                                        <ItemsControl Margin="0,8,0,0"
                                                                      ItemsSource="{Binding Steps}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,0,0,10">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="34" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <Border Width="24"
                                                                                Height="24"
                                                                                Background="#E7F6EF"
                                                                                CornerRadius="12">
                                                                            <TextBlock HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="#256D5A"
                                                                                       Text="{Binding SortOrder}" />
                                                                        </Border>

                                                                        <StackPanel Grid.Column="1">
                                                                            <DockPanel LastChildFill="True">
                                                                                <Button DockPanel.Dock="Right"
                                                                                        Command="{Binding DataContext.ShowEditTestStepResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        CommandParameter="{Binding}"
                                                                                        Content="Update"
                                                                                        Style="{StaticResource CheckActionButtonStyle}" />
                                                                                <Button DockPanel.Dock="Right"
                                                                                        Command="{Binding DataContext.ShowTestStepDiscussionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        CommandParameter="{Binding}"
                                                                                        Content="Chat"
                                                                                        Style="{StaticResource CheckActionButtonStyle}" />
                                                                                <Border DockPanel.Dock="Right"
                                                                                        Padding="8,3"
                                                                                        Background="{Binding StatusBackground}"
                                                                                        CornerRadius="4">
                                                                                    <TextBlock FontWeight="SemiBold"
                                                                                               Foreground="{Binding StatusForeground}"
                                                                                               Text="{Binding StatusDisplay}" />
                                                                                </Border>
                                                                                <TextBlock FontWeight="SemiBold"
                                                                                           Text="{Binding CheckText}"
                                                                                           TextWrapping="Wrap" />
                                                                            </DockPanel>
                                                                            <TextBlock Margin="0,5,0,0"
                                                                                       Foreground="#64748B"
                                                                                       Text="{Binding ExpectedResult}"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Margin="0,5,0,0"
                                                                                       Foreground="#475569"
                                                                                       Text="{Binding CommentDisplay}"
                                                                                       TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Background="#990F172A"
                Visibility="{Binding ManualDialogOverlayVisibility}">
            <Border Width="520"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="{Binding ManualDialogTitle}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="2">
                        <TextBlock Foreground="#64748B"
                                   Text="Name or title" />
                        <TextBox Margin="0,6,0,14"
                                 MinHeight="34"
                                 Text="{Binding ManualItemName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Foreground="#64748B"
                                   Text="Category, expected result, or details" />
                        <TextBox Margin="0,6,0,0"
                                 MinHeight="110"
                                 AcceptsReturn="True"
                                 Text="{Binding ManualItemDescription, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock Grid.Row="4"
                               Margin="0,0,0,14"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="5"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseManualItemDialogCommand}"
                                Content="Cancel" />
                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding SaveManualItemCommand}"
                                Content="Save" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Background="#990F172A"
                Visibility="{Binding ResultDialogOverlayVisibility}">
            <Border Width="560"
                    MaxWidth="620"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                MinHeight="30"
                                MinWidth="72"
                                Command="{Binding ShowCurrentResultDiscussionCommand}"
                                Content="Chat" />
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="{Binding ResultDialogTitle}"
                                   TextWrapping="Wrap" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="420"
                                  VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Foreground="#64748B"
                                   Text="Status" />
                        <ComboBox Margin="0,6,0,14"
                                  MinHeight="34"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding ResultStatuses}"
                                  SelectedItem="{Binding SelectedResultStatus}" />

                        <TextBlock Foreground="#64748B"
                                   Text="Comment" />
                        <TextBox Margin="0,6,0,0"
                                 MinHeight="110"
                                 AcceptsReturn="True"
                                 Text="{Binding ResultComment, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" />

                        <Grid Margin="0,18,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Attachments" />
                            <Button Grid.Column="1"
                                    Command="{Binding AddAttachmentCommand}"
                                    Content="Add Attachment"
                                    Style="{StaticResource SmallActionButtonStyle}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ResultAttachments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="84" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="72"
                                                    Height="54"
                                                    Background="#F1F5F9"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                <Image Source="{Binding AbsolutePath}"
                                                       Stretch="UniformToFill">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Margin="0,0,12,0">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding OriginalFileName}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,3,0,0"
                                                           Foreground="#64748B"
                                                           Text="{Binding DetailsDisplay}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal">
                                                <Button Margin="0,0,8,0"
                                                        Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Open"
                                                        Style="{StaticResource SmallActionButtonStyle}" />
                                                <Button Command="{Binding DataContext.DeleteAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Delete"
                                                        Foreground="#B91C1C"
                                                        Style="{StaticResource SmallActionButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,18,0,6"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Linked Bug" />
                        <TextBlock Foreground="#64748B"
                                   Text="{Binding LinkedBugTargetDisplay}"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,10,0,6"
                                   Foreground="#64748B"
                                   Text="Bug title" />
                        <TextBox MinHeight="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding LinkedBugTitle, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,6"
                                   Foreground="#64748B"
                                   Text="Bug description" />
                        <TextBox MinHeight="80"
                                 AcceptsReturn="True"
                                 Text="{Binding LinkedBugDescription, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" />

                        <Button Margin="0,12,0,0"
                                MinHeight="34"
                                HorizontalAlignment="Right"
                                Command="{Binding CreateLinkedBugCommand}"
                                Content="Create Linked Bug" />
                    </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="4"
                               Margin="0,0,0,14"
                               Foreground="#64748B"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="5"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseResultDialogCommand}"
                                Content="Cancel" />
                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding SaveResultCommand}"
                                Content="Save"
                                IsDefault="True" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Panel.ZIndex="30"
                Background="#330F172A"
                Visibility="{Binding DiscussionDrawerVisibility}">
            <Border Width="440"
                    Padding="18"
                    HorizontalAlignment="Right"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,14">
                        <Button DockPanel.Dock="Right"
                                MinHeight="30"
                                MinWidth="72"
                                Command="{Binding CloseDiscussionCommand}"
                                Content="Close" />
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="{Binding DiscussionTitle}"
                                   TextWrapping="Wrap" />
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding DiscussionComments}"
                             ItemContainerStyle="{StaticResource FullWidthListBoxItemStyle}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="10"
                                        Background="White"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal">
                                                <Button MinWidth="48"
                                                        Command="{Binding DataContext.EditDiscussionMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Edit" />
                                                <Button MinWidth="56"
                                                        Margin="6,0,0,0"
                                                        Foreground="#B91C1C"
                                                        Command="{Binding DataContext.DeleteDiscussionMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Delete" />
                                            </StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="#256D5A"
                                                       Text="{Binding HeaderDisplay}"
                                                       TextWrapping="Wrap" />
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#172033"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,5,0,0"
                                                   Foreground="#94A3B8"
                                                   Text="{Binding EditedDisplay}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="White"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="{Binding DiscussionEditorTitle}" />
                            <TextBox Margin="0,8,0,10"
                                     MinHeight="82"
                                     AcceptsReturn="True"
                                     Text="{Binding DiscussionMessage, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />
                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <Button MinWidth="76"
                                        Margin="0,0,8,0"
                                        Command="{Binding CancelDiscussionEditCommand}"
                                        Content="Clear" />
                                <Button MinWidth="110"
                                        Command="{Binding SaveDiscussionMessageCommand}"
                                        Content="{Binding DiscussionSaveButtonText}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
