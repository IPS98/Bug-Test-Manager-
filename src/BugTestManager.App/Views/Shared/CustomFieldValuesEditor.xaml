<UserControl x:Class="BugTestManager.App.Views.Shared.CustomFieldValuesEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:domainEnums="clr-namespace:BugTestManager.Domain.Enums;assembly=BugTestManager.Domain">
    <StackPanel Margin="0,4,0,16">
        <StackPanel.Style>
            <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Count}" Value="0">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </StackPanel.Style>

        <TextBlock Margin="0,0,0,8"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#172033"
                   Text="Custom Fields" />

        <ItemsControl ItemsSource="{Binding}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="10"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Right"
                                           Foreground="#94A3B8"
                                           Text="{Binding FieldTypeDisplay}" />
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="#172033"
                                           Text="{Binding HeaderDisplay}"
                                           TextWrapping="Wrap" />
                            </DockPanel>

                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Setter Property="AcceptsReturn" Value="False" />
                                        <Setter Property="MinHeight" Value="34" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FieldType}" Value="{x:Static domainEnums:FieldType.LongText}">
                                                <Setter Property="AcceptsReturn" Value="True" />
                                                <Setter Property="MinHeight" Value="82" />
                                                <Setter Property="VerticalContentAlignment" Value="Top" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FieldType}" Value="{x:Static domainEnums:FieldType.SingleSelect}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FieldType}" Value="{x:Static domainEnums:FieldType.Checkbox}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <ComboBox MinHeight="34"
                                      ItemsSource="{Binding Options}"
                                      SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FieldType}" Value="{x:Static domainEnums:FieldType.SingleSelect}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>

                            <CheckBox Content="Yes"
                                      IsChecked="{Binding BoolValue, UpdateSourceTrigger=PropertyChanged}">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FieldType}" Value="{x:Static domainEnums:FieldType.Checkbox}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>

                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       Text="{Binding OptionsDisplay}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding OptionsVisibility}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
