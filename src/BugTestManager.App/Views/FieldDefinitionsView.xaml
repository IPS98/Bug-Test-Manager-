<UserControl x:Class="BugTestManager.App.Views.FieldDefinitionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SmallActionButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="18"
                Background="White"
                CornerRadius="8">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="New Field" />

                <TextBlock Margin="0,18,0,6"
                           Foreground="#64748B"
                           Text="Where this field appears" />
                <ComboBox MinHeight="34"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding TargetEntityTypes}"
                          SelectedItem="{Binding SelectedTargetEntityType}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Available in" />
                <ComboBox MinHeight="34"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding ScopeOptions}"
                          SelectedItem="{Binding SelectedScopeOption}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Name" />
                <TextBox MinHeight="34"
                         VerticalContentAlignment="Center"
                         Text="{Binding NewFieldName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Type" />
                <ComboBox MinHeight="34"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding FieldTypes}"
                          SelectedItem="{Binding SelectedFieldType}" />

                <CheckBox Margin="0,16,0,0"
                          Content="Required"
                          IsChecked="{Binding NewFieldIsRequired}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Sort order" />
                <TextBox MinHeight="34"
                         VerticalContentAlignment="Center"
                         Text="{Binding NewFieldSortOrder, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Options" />
                <TextBox MinHeight="78"
                         AcceptsReturn="True"
                         Text="{Binding NewFieldOptionsText, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" />

                <Button Margin="0,18,0,0"
                        MinHeight="36"
                        HorizontalAlignment="Stretch"
                        Command="{Binding CreateFieldCommand}"
                        Content="Create Field" />

                <TextBlock Margin="0,14,0,0"
                           Foreground="#64748B"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Padding="18"
                Background="White"
                CornerRadius="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,14"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="Field Definitions" />

                <ListBox ItemsSource="{Binding Fields}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,14,0">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding TargetDisplay}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding ScopeDisplayName}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding OptionsDisplay}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="#256D5A"
                                               Text="{Binding FieldTypeDisplay}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding RequirementDisplay}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding StatusDisplay}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.ShowEditFieldDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Edit"
                                            Style="{StaticResource SmallActionButtonStyle}" />
                                    <Button Margin="8,0,0,0"
                                            Command="{Binding DataContext.ArchiveFieldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Archive"
                                            Style="{StaticResource SmallActionButtonStyle}" />
                                    <Button Margin="8,0,0,0"
                                            Command="{Binding DataContext.ShowDeleteFieldDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Delete"
                                            Foreground="#B91C1C"
                                            Style="{StaticResource SmallActionButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.ColumnSpan="3"
                Background="#990F172A"
                Visibility="{Binding EditFieldDialogVisibility}">
            <Border Width="540"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="Edit Field" />

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="520"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Foreground="#64748B"
                                       Text="Where this field appears" />
                            <ComboBox Margin="0,6,0,14"
                                      MinHeight="34"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding TargetEntityTypes}"
                                      SelectedItem="{Binding EditTargetEntityType}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Available in" />
                            <ComboBox Margin="0,6,0,14"
                                      MinHeight="34"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding ScopeOptions}"
                                      SelectedItem="{Binding EditScopeOption}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Name" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding EditFieldName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Type" />
                            <ComboBox Margin="0,6,0,14"
                                      MinHeight="34"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding FieldTypes}"
                                      SelectedItem="{Binding EditFieldType}" />

                            <CheckBox Margin="0,2,0,14"
                                      Content="Required"
                                      IsChecked="{Binding EditFieldIsRequired}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Sort order" />
                            <TextBox Margin="0,6,0,14"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding EditFieldSortOrder, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Foreground="#64748B"
                                       Text="Options" />
                            <TextBox Margin="0,6,0,0"
                                     MinHeight="90"
                                     AcceptsReturn="True"
                                     Text="{Binding EditFieldOptionsText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseEditFieldDialogCommand}"
                                Content="Cancel" />
                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding UpdateFieldCommand}"
                                Content="Save" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.ColumnSpan="3"
                Background="#990F172A"
                Visibility="{Binding DeleteFieldDialogVisibility}">
            <Border Width="480"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               Text="{Binding DeleteFieldTitle}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2"
                               Foreground="#64748B"
                               Text="{Binding DeleteFieldWarning}"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="4"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                MinHeight="34"
                                Margin="0,0,10,0"
                                Command="{Binding CloseDeleteFieldDialogCommand}"
                                Content="Cancel" />
                        <Button MinWidth="92"
                                MinHeight="34"
                                Command="{Binding ConfirmDeleteFieldCommand}"
                                Content="Delete"
                                Foreground="#B91C1C" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
