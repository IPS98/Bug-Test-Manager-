<UserControl x:Class="BugTestManager.App.Views.FieldDefinitionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="18"
                Background="White"
                CornerRadius="8">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="New Field" />

                <TextBlock Margin="0,18,0,6"
                           Foreground="#64748B"
                           Text="Where this field appears" />
                <ComboBox MinHeight="34"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding TargetEntityTypes}"
                          SelectedItem="{Binding SelectedTargetEntityType}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Available in" />
                <ComboBox MinHeight="34"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding ScopeOptions}"
                          SelectedItem="{Binding SelectedScopeOption}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Name" />
                <TextBox MinHeight="34"
                         VerticalContentAlignment="Center"
                         Text="{Binding NewFieldName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Type" />
                <ComboBox MinHeight="34"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding FieldTypes}"
                          SelectedItem="{Binding SelectedFieldType}" />

                <CheckBox Margin="0,16,0,0"
                          Content="Required"
                          IsChecked="{Binding NewFieldIsRequired}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Sort order" />
                <TextBox MinHeight="34"
                         VerticalContentAlignment="Center"
                         Text="{Binding NewFieldSortOrder, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,14,0,6"
                           Foreground="#64748B"
                           Text="Options" />
                <TextBox MinHeight="78"
                         AcceptsReturn="True"
                         Text="{Binding NewFieldOptionsText, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" />

                <Button Margin="0,18,0,0"
                        MinHeight="36"
                        HorizontalAlignment="Stretch"
                        Command="{Binding CreateFieldCommand}"
                        Content="Create Field" />

                <TextBlock Margin="0,14,0,0"
                           Foreground="#64748B"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Padding="18"
                Background="White"
                CornerRadius="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,14"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#172033"
                           Text="Field Definitions" />

                <ListBox ItemsSource="{Binding Fields}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,14,0">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding TargetDisplay}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding ScopeDisplayName}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding OptionsDisplay}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="#256D5A"
                                               Text="{Binding FieldTypeDisplay}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding RequirementDisplay}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#64748B"
                                               Text="{Binding StatusDisplay}" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        MinWidth="76"
                                        MinHeight="30"
                                        VerticalAlignment="Center"
                                        Command="{Binding DataContext.ArchiveFieldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="Archive" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
