<UserControl x:Class="BugTestManager.App.Views.PlaceholderPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="28"
            Background="White"
            CornerRadius="8">
        <StackPanel>
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#172033"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="15"
                       Foreground="#4A5872"
                       Text="{Binding Message}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
