<UserControl x:Class="BugTestManager.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ReportMetaChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Padding="22"
                Background="White"
                CornerRadius="8">
            <DockPanel>
                <Grid DockPanel.Dock="Top"
                      Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"
                                   Text="Report Builder" />
                        <TextBlock Margin="0,5,0,0"
                                   Foreground="#64748B"
                                   Text="Prepare complete report data before PDF generation."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal">
                        <ComboBox Width="420"
                                  MinHeight="34"
                                  DisplayMemberPath="SelectorDisplay"
                                  ItemsSource="{Binding Sessions}"
                                  SelectedItem="{Binding SelectedSession}"
                                  ToolTip="Select test session for report" />
                        <Button Margin="10,0,0,0"
                                Command="{Binding LoadReportCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTip="Prepare report data for selected session">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ActionIconTextStyle}" Text="&#xE9F9;" />
                                <TextBlock Text="Prepare" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Padding="12"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="6">
                            <TextBlock Foreground="#475569"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <StackPanel Margin="0,18,0,0"
                                    Visibility="{Binding ReportVisibility}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="16"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock FontSize="17"
                                                   FontWeight="SemiBold"
                                                   Foreground="#172033"
                                                   Text="{Binding SelectedReport.SessionName}"
                                                   TextWrapping="Wrap" />
                                        <WrapPanel Margin="0,12,0,0">
                                            <Border Margin="0,0,8,8"
                                                    Style="{StaticResource GreenChipBorderStyle}">
                                                <TextBlock Style="{StaticResource GreenChipTextStyle}"
                                                           Text="{Binding SelectedReport.ProjectName}" />
                                            </Border>
                                            <Border Margin="0,0,8,8"
                                                    Style="{StaticResource ReportMetaChipStyle}">
                                                <TextBlock Foreground="#64748B"
                                                           Text="{Binding SelectedReport.TestSuiteName}" />
                                            </Border>
                                            <Border Margin="0,0,8,8"
                                                    Style="{StaticResource ReportMetaChipStyle}">
                                                <TextBlock Foreground="#64748B"
                                                           Text="{Binding SelectedReport.TestSuiteRevisionName, TargetNullValue=No revision}" />
                                            </Border>
                                            <Border Margin="0,0,8,8"
                                                    Style="{StaticResource ReportMetaChipStyle}">
                                                <TextBlock Foreground="#64748B"
                                                           Text="{Binding SelectedReport.TestedVersion, StringFormat=Version: {0}}" />
                                            </Border>
                                            <Border Margin="0,0,8,8"
                                                    Style="{StaticResource ReportMetaChipStyle}">
                                                <TextBlock Foreground="#64748B"
                                                           Text="{Binding SelectedReport.BuildNumber, StringFormat=Build: {0}}" />
                                            </Border>
                                        </WrapPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#475569"
                                                   Text="{Binding SelectedReport.Notes}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="16"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#172033"
                                                   Text="Status Summary" />
                                        <UniformGrid Margin="0,12,0,0"
                                                     Columns="2">
                                            <TextBlock Text="{Binding SelectedReport.Summary.Passed, StringFormat=Passed: {0}}" />
                                            <TextBlock Text="{Binding SelectedReport.Summary.Failed, StringFormat=Failed: {0}}" />
                                            <TextBlock Text="{Binding SelectedReport.Summary.Blocked, StringFormat=Blocked: {0}}" />
                                            <TextBlock Text="{Binding SelectedReport.Summary.NotTested, StringFormat=Not tested: {0}}" />
                                            <TextBlock Text="{Binding SelectedReport.Summary.NotApplicable, StringFormat=N/A: {0}}" />
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding SelectedReport.Summary.Total, StringFormat=Total: {0}}" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Margin="0,20,0,10"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="Report Content Preview" />

                            <ItemsControl ItemsSource="{Binding SelectedReport.Sections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,14"
                                                Padding="14"
                                                Background="#F8FAFC"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="#172033"
                                                           Text="{Binding Name}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,4,0,10"
                                                           Foreground="#64748B"
                                                           Text="{Binding Category}"
                                                           TextWrapping="Wrap" />

                                                <ItemsControl ItemsSource="{Binding TestCases}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,0,10"
                                                                    Padding="12"
                                                                    Background="White"
                                                                    BorderBrush="#E2E8F0"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6">
                                                                <StackPanel>
                                                                    <DockPanel LastChildFill="True">
                                                                        <Border DockPanel.Dock="Right"
                                                                                Padding="8,3"
                                                                                Background="#EEF6FF"
                                                                                CornerRadius="4">
                                                                            <TextBlock FontWeight="SemiBold"
                                                                                       Foreground="#172033"
                                                                                       Text="{Binding Status}" />
                                                                        </Border>
                                                                        <TextBlock FontWeight="SemiBold"
                                                                                   Text="{Binding Title}"
                                                                                   TextWrapping="Wrap" />
                                                                    </DockPanel>
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Foreground="#64748B"
                                                                               Text="{Binding ExpectedResult}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Foreground="#475569"
                                                                               Text="{Binding Comment}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,8,0,0"
                                                                               Foreground="#64748B"
                                                                               Text="{Binding Checks.Count, StringFormat=Checks: {0}}" />
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               Foreground="#64748B"
                                                                               Text="{Binding Attachments.Count, StringFormat=Attachments: {0}}" />
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               Foreground="#64748B"
                                                                               Text="{Binding CustomFields.Count, StringFormat=Custom fields: {0}}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Margin="0,10,0,10"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       Text="{Binding SelectedReport.LinkedBugs.Count, StringFormat=Linked Bugs: {0}}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
